# Database (Neon Serverless Postgres)
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# Better Auth Configuration
BETTER_AUTH_SECRET="your-better-auth-secret-use-openssl-rand-hex-32"
BETTER_AUTH_URL="http://localhost:3000" # URL of your web app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Bootstrapping Admin Account
SUPER_ADMIN_EMAIL="admin@motionsewa.com"

# Resend Email Integration
RESEND_API_KEY="re_your_resend_api_key"
FROM_EMAIL="Your Drive <onboarding@website.com>"

# Cloudflare R2 S3-Compatible Credentials
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_ENDPOINT="https://<your-cloudflare-account-id>.r2.cloudflarestorage.com"
R2_BUCKET_NAME="video-assets"

# Backblaze B2 S3-Compatible Credentials (Archive Drive)
B2_KEY_ID="your-b2-key-id"
B2_APPLICATION_KEY="your-b2-application-key"
B2_ENDPOINT="https://s3.<region>.backblazeb2.com"
B2_BUCKET_NAME="your-b2-bucket-name"

# Google OAuth Credentials (for Better Auth)
GOOGLE_CLIENT_ID="your-google-web-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Native mobile Google Sign-In
# The app can read GOOGLE_CLIENT_ID through /api/auth/google/native-config.
# NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID is optional if you want to bundle it directly.
# Also configure Android OAuth client in Google Cloud Console:
# package name com.motionsewa.drive plus your debug/release SHA-1 and SHA-256 fingerprints.
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=""
